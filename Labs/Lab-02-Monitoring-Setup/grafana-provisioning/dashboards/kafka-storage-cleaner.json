{
  "id": null,
  "uid": "kafka-storage-cleaner",
  "title": "Kafka - Storage & Log Cleaner",
  "tags": ["kafka", "training", "storage", "retention"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "editable": true,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Log cleaner max dirty %",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "max(kafka_log_cleaner_max_dirty_percent)",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "value": null, "color": "green" },
          { "value": 50, "color": "yellow" },
          { "value": 90, "color": "red" }
        ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },

    {
      "id": 2, "type": "stat", "title": "Uncleanable partitions  (should be 0)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A",
        "expr": "sum(kafka_log_cleaner_uncleanable_partitions_count)",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "value": null, "color": "green" },
          { "value": 1, "color": "red" }
        ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },

    {
      "id": 3, "type": "stat", "title": "Total data on disk (all replicas)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(kafka_log_size)",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "bytes",
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },

    {
      "id": 4, "type": "stat", "title": "Time since last cleaner run",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A",
        "expr": "max(kafka_log_cleaner_time_since_last_run_ms) / 1000",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "value": null, "color": "green" },
          { "value": 60, "color": "yellow" },
          { "value": 300, "color": "red" }
        ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },

    {
      "id": 5, "type": "timeseries", "title": "Log size per topic  (Sc 5.1 · retention watches this drop; Sc 5.2 · reassignment moves it)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A",
        "expr": "sum by (topic) (kafka_log_size{topic!~\"__.*\"})",
        "legendFormat": "{{topic}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "bytes",
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
          "fillOpacity": 30, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true,
          "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 6, "type": "timeseries", "title": "Segment count per topic  (Sc 5.1 · small segment.ms → many segments)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A",
        "expr": "sum by (topic) (kafka_log_numlogsegments{topic!~\"__.*\"})",
        "legendFormat": "{{topic}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0,
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2,
          "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true,
          "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 7, "type": "timeseries", "title": "Log growth rate per topic (offsets / s appended)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A",
        "expr": "sum by (topic) (rate(kafka_log_logendoffset{topic!~\"__.*\"}[1m]))",
        "legendFormat": "{{topic}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short",
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
          "fillOpacity": 20 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true,
          "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 8, "type": "timeseries", "title": "Log cleaner max dirty % over time  (Sc 5.1 · compaction demo)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "max(kafka_log_cleaner_max_dirty_percent)",
        "legendFormat": "max dirty %",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
          "fillOpacity": 20 },
        "thresholds": { "mode": "absolute", "steps": [
          { "value": null, "color": "green" },
          { "value": 50, "color": "yellow" },
          { "value": 90, "color": "red" }
        ] } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" } }
    }

  ]
}
